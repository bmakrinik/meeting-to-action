# Copy to .env.local and fill in. Never commit .env.local.

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Google Drive ---
# Path to a Google OAuth or service-account credentials JSON with Drive read + trash scope.
# The folder below is the Google Meet "Meet Recordings" folder ID (from its Drive URL).
GOOGLE_CREDENTIALS_PATH=./credentials/google.json
# Optional: token cache for OAuth user flow (created on first auth)
GOOGLE_TOKEN_PATH=./credentials/google-token.json
MEET_RECORDINGS_FOLDER_ID=

# --- Notion ---
NOTION_TOKEN=secret_...
# Target database ID (one page will be created per meeting).
NOTION_DATABASE_ID=

# --- Access control (HTTP Basic Auth) ---
# When BOTH are set, middleware.ts requires HTTP Basic Auth on every route except
# /api/health, with a per-IP brute-force limiter. Leave blank to disable (the app
# is then open — fine for local dev, not for the public deployment).
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# --- Local dev convenience ---
# If set, drive.ts reads .mp4 files from this local folder instead of Google Drive.
# Use for testing the pipeline without Drive credentials.
LOCAL_FIXTURE_DIR=
# Where downloaded MP4s / extracted audio land.
WORK_DIR=./data/work
